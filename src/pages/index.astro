---
import '../styles/global.css';

const navLinks = [
  ['Portfolio', '#portfolio', ''],
  ['Timeline', '#timeline', ''],
  ['About', '#about', ''],
  ['Contact', '#contact', 'hidden sm:inline']
];

const istockUrl = 'https://www.istockphoto.com/th/portfolio/KrittawatS';

const photos = [
  {
    src: 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=86',
    alt: 'Small house in a wide green landscape under soft afternoon light',
    title: 'Quiet Fields',
    span: 'md:col-span-2'
  },
  {
    src: 'https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?auto=format&fit=crop&w=900&q=86',
    alt: 'Open desert road leading toward a distant mountain range',
    title: 'Open Road',
    span: ''
  },
  {
    src: 'https://images.unsplash.com/photo-1519681393784-d120267933ba?auto=format&fit=crop&w=900&q=86',
    alt: 'Starry night sky over a mountain lake',
    title: 'Night Water',
    span: ''
  },
  {
    src: 'https://images.unsplash.com/photo-1493246507139-91e8fad9978e?auto=format&fit=crop&w=1100&q=86',
    alt: 'Forest trail surrounded by deep green trees',
    title: 'Still Green',
    span: 'md:col-span-2'
  },
  {
    src: 'https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=900&q=86',
    alt: 'Mountain valley with a bright lake and low clouds',
    title: 'High Lake',
    span: ''
  },
  {
    src: 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=900&q=86',
    alt: 'Ocean shore with clear turquoise water and pale sand',
    title: 'Low Tide',
    span: ''
  },
  {
    src: 'https://images.unsplash.com/photo-1500534623283-312aade485b7?auto=format&fit=crop&w=1100&q=86',
    alt: 'Rocky canyon lit by warm evening sun',
    title: 'Warm Stone',
    span: 'md:col-span-2'
  },
  {
    src: 'https://images.unsplash.com/photo-1511818966892-d7d671e672a2?auto=format&fit=crop&w=900&q=86',
    alt: 'Minimal interior detail with morning light falling across a wall',
    title: 'Morning Line',
    span: ''
  }
];

const timeline = [
  {
    place: 'Vik, Iceland',
    title: 'Church on the south coast',
    note: 'A small landmark against wide northern weather.',
    year: '01'
  },
  {
    place: 'East Java, Indonesia',
    title: 'Mount Bromo',
    note: 'Volcanic texture, open air, and a landscape that feels older than the road.',
    year: '02'
  },
  {
    place: 'Bangkok, Thailand',
    title: 'Benjakitti Park',
    note: 'A local pause: green paths, city edges, and everyday light close to home.',
    year: '03'
  },
  {
    place: 'Yamanashi, Japan',
    title: 'Mount Fuji',
    note: 'A clean horizon, quiet distance, and the kind of shape that simplifies a frame.',
    year: '04'
  },
  {
    place: 'Fuji Five Lakes, Japan',
    title: 'Fuji reflection',
    note: 'Still water turning the mountain into a slower photograph.',
    year: '05'
  }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="A minimal photography portfolio by Krittawat Sup, focused on quiet landscapes, travel, light, and everyday composition."
    />
    <meta property="og:title" content="Krittawat Sup | Photography" />
    <meta
      property="og:description"
      content="Minimal photography portfolio focused on quiet landscapes, travel, light, and everyday composition."
    />
    <meta property="og:type" content="website" />
    <title>Krittawat Sup | Photography</title>
  </head>
  <body class="bg-[#f8f7f2] text-[#181818] antialiased">
    <main>
      <section class="min-h-svh px-4 py-4 sm:px-6 lg:px-8">
        <div class="mx-auto flex min-h-[calc(100svh-2rem)] w-full max-w-[1480px] flex-col border border-[#181818]/15 bg-[#fbfaf6]">
          <header class="flex min-h-16 w-full min-w-0 items-center justify-between gap-4 border-b border-[#181818]/12 px-4 sm:px-6 lg:px-8">
            <a href="/" class="text-xs font-medium uppercase tracking-[0.2em] sm:text-sm sm:tracking-[0.28em]">Krittawat Sup</a>
            <nav class="hidden items-center gap-7 text-[11px] uppercase tracking-[0.22em] text-[#181818]/70 sm:flex">
              {navLinks.map(([label, href, className]) => (
                <a href={href} class={`transition hover:text-[#181818] ${className}`}>{label}</a>
              ))}
            </nav>
          </header>

          <div class="grid flex-1 lg:grid-cols-[0.72fr_1.28fr]">
            <div class="flex min-w-0 flex-col justify-center px-5 py-12 sm:px-8 lg:px-10">
              <p class="text-xs uppercase tracking-[0.34em] text-[#181818]/50">Photography</p>
              <h1 class="mt-5 max-w-[20rem] text-4xl font-normal leading-[1.05] sm:max-w-2xl sm:text-7xl sm:leading-[0.98] lg:text-8xl">
                Quiet frames from <span class="block">ordinary light.</span>
              </h1>
              <p class="mt-7 max-w-[19rem] text-base leading-8 text-[#181818]/62 sm:max-w-md">
                A personal collection of landscapes, city corners, travel fragments, and small moments that stayed long enough to photograph.
              </p>
              <a
                href={istockUrl}
                class="mt-8 w-fit border-b border-[#181818] pb-1 text-xs uppercase tracking-[0.24em] text-[#181818] transition hover:text-[#181818]/55"
              >
                View iStock portfolio
              </a>
            </div>

            <figure class="relative min-h-[56svh] border-t border-[#181818]/12 lg:min-h-0 lg:border-l lg:border-t-0">
              <img
                class="absolute inset-0 h-full w-full object-cover"
                src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1800&q=88"
                alt="Wide landscape with a small house, hills, and soft natural light"
              />
              <figcaption class="absolute bottom-0 left-0 bg-[#fbfaf6]/90 px-4 py-3 text-xs uppercase tracking-[0.22em] text-[#181818]/70 backdrop-blur">
                Selected photographs
              </figcaption>
            </figure>
          </div>
        </div>
      </section>

      <section id="portfolio" class="px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
        <div class="mx-auto max-w-[1480px]">
          <div class="mb-8 flex flex-col gap-3 border-b border-[#181818]/14 pb-5 sm:flex-row sm:items-end sm:justify-between">
            <h2 class="text-3xl font-normal tracking-tight sm:text-4xl">Portfolio</h2>
            <p class="max-w-xl text-sm leading-7 text-[#181818]/58">
              Landscape, travel, nature, and still compositions. The page keeps the photographs first.
            </p>
          </div>

          <div class="grid auto-rows-[260px] grid-cols-1 gap-3 sm:auto-rows-[320px] md:grid-cols-3 lg:auto-rows-[380px]">
            {photos.map((photo) => (
              <button
                class={`group relative overflow-hidden bg-[#e8e5dc] text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-[#181818] focus-visible:ring-offset-4 focus-visible:ring-offset-[#f8f7f2] ${photo.span}`}
                type="button"
                data-gallery-trigger
                data-title={photo.title}
                data-src={photo.src}
                data-alt={photo.alt}
                aria-label={`Open ${photo.title}`}
              >
                <img
                  class="portfolio-photo h-full w-full object-cover"
                  src={photo.src}
                  alt={photo.alt}
                />
                <span class="absolute inset-x-0 bottom-0 flex items-end justify-between gap-4 bg-gradient-to-t from-black/60 to-transparent px-4 pb-4 pt-16 text-white opacity-100 transition-all duration-700 ease-[cubic-bezier(0.19,1,0.22,1)] md:translate-y-3 md:opacity-0 md:group-hover:translate-y-0 md:group-hover:opacity-100">
                  <span class="text-sm uppercase tracking-[0.22em]">{photo.title}</span>
                  <span class="text-xs uppercase tracking-[0.2em] text-white/72">View</span>
                </span>
              </button>
            ))}
          </div>
        </div>
      </section>

      <section id="timeline" class="px-4 pb-16 sm:px-6 lg:px-8 lg:pb-24">
        <div class="mx-auto max-w-[1480px] border-t border-[#181818]/14 pt-10">
          <div class="grid gap-8 lg:grid-cols-[0.72fr_1.28fr]">
            <div>
              <p class="text-xs uppercase tracking-[0.34em] text-[#181818]/50">Travel timeline</p>
              <h2 class="mt-4 max-w-md text-3xl font-normal leading-tight sm:text-5xl">
                Places collected through light, weather, and distance.
              </h2>
              <p class="mt-5 max-w-sm text-sm leading-7 text-[#181818]/58">
                A quiet route through selected travel frames, including the subjects currently listed in my iStock portfolio.
              </p>
              <a
                href={istockUrl}
                class="mt-7 inline-flex border-b border-[#181818] pb-1 text-xs uppercase tracking-[0.22em] text-[#181818] transition hover:text-[#181818]/55"
              >
                Krittawat S on iStock
              </a>
            </div>

            <ol class="border-t border-[#181818]/14 lg:border-t-0">
              {timeline.map((stop) => (
                <li class="grid gap-4 border-b border-[#181818]/14 py-6 sm:grid-cols-[5rem_0.9fr_1.1fr] sm:gap-6">
                  <span class="text-xs uppercase tracking-[0.28em] text-[#181818]/42">{stop.year}</span>
                  <div>
                    <p class="text-xs uppercase tracking-[0.26em] text-[#181818]/45">{stop.place}</p>
                    <h3 class="mt-2 text-2xl font-normal leading-tight">{stop.title}</h3>
                  </div>
                  <p class="text-sm leading-7 text-[#181818]/62">{stop.note}</p>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </section>

      <section id="about" class="px-4 pb-16 sm:px-6 lg:px-8 lg:pb-24">
        <div class="mx-auto grid max-w-[1480px] gap-10 border-t border-[#181818]/14 pt-10 md:grid-cols-[0.8fr_1.2fr]">
          <p class="text-xs uppercase tracking-[0.34em] text-[#181818]/50">About</p>
          <div class="max-w-3xl">
            <h2 class="text-3xl font-normal leading-tight sm:text-5xl">
              I photograph places the way I like to remember them: simple, quiet, and slightly unfinished.
            </h2>
            <p class="mt-6 text-base leading-8 text-[#181818]/62">
              This page is less about a resume and more about visual notes. Work exists in the background; the photographs do the talking here.
            </p>
          </div>
        </div>
      </section>

      <footer id="contact" class="border-t border-[#181818]/14 px-4 py-8 sm:px-6 lg:px-8">
        <div class="mx-auto flex max-w-[1480px] flex-col gap-4 text-sm text-[#181818]/62 sm:flex-row sm:items-center sm:justify-between">
          <p>Bangkok based. Available for selected creative collaborations.</p>
          <div class="flex gap-5">
            <a class="text-[#181818] underline" href={istockUrl}>iStock</a>
            <a class="text-[#181818] underline" href="https://github.com/kratuwu">GitHub</a>
            <a class="text-[#181818] underline" href="https://linkedin.com/in/krittawat-sup">LinkedIn</a>
          </div>
        </div>
      </footer>

      <dialog
        id="gallery-modal"
        class="gallery-dialog w-[min(100%-2rem,1180px)] max-w-none bg-transparent p-0 text-[#181818]"
        aria-labelledby="gallery-modal-title"
      >
        <div class="gallery-dialog-panel bg-[#fbfaf6]">
          <div class="flex items-center justify-between gap-4 border-b border-[#181818]/14 px-4 py-3 sm:px-5">
            <h2 id="gallery-modal-title" class="text-xs uppercase tracking-[0.26em]">Photograph</h2>
            <button
              id="gallery-modal-close"
              class="flex h-9 w-9 items-center justify-center text-base leading-none transition"
              type="button"
              aria-label="Close"
            >
              X
            </button>
          </div>
          <img id="gallery-modal-image" class="max-h-[78svh] w-full bg-[#e8e5dc] object-contain" src="" alt="" />
          <p id="gallery-modal-caption" class="px-4 py-4 text-sm leading-7 text-[#181818]/62 sm:px-5"></p>
        </div>
      </dialog>
    </main>

    <script>
      const modal = document.querySelector('#gallery-modal');
      const modalImage = document.querySelector('#gallery-modal-image');
      const modalTitle = document.querySelector('#gallery-modal-title');
      const modalCaption = document.querySelector('#gallery-modal-caption');
      const closeButton = document.querySelector('#gallery-modal-close');
      const triggers = document.querySelectorAll('[data-gallery-trigger]');
      let activeTrigger = null;
      let closeTimer = null;

      const closeModal = () => {
        if (!(modal instanceof HTMLDialogElement) || !modal.open || modal.dataset.closing === 'true') return;
        modal.dataset.closing = 'true';
        modal.dataset.entered = 'false';
        closeTimer = window.setTimeout(() => {
          modal.close();
          modal.dataset.closing = 'false';
          modal.dataset.entered = 'false';
          activeTrigger?.focus();
        }, 380);
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener('click', () => {
          if (
            !(modal instanceof HTMLDialogElement) ||
            !(modalImage instanceof HTMLImageElement) ||
            !(modalTitle instanceof HTMLElement) ||
            !(modalCaption instanceof HTMLElement)
          ) {
            return;
          }

          activeTrigger = trigger;
          const title = trigger.getAttribute('data-title') ?? 'Photograph';
          const src = trigger.getAttribute('data-src') ?? '';
          const alt = trigger.getAttribute('data-alt') ?? title;

          modalTitle.textContent = title;
          modalImage.src = src;
          modalImage.alt = alt;
          modalCaption.textContent = alt;
          if (closeTimer) window.clearTimeout(closeTimer);
          modal.dataset.closing = 'false';
          modal.dataset.entered = 'false';
          modal.showModal();
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              modal.dataset.entered = 'true';
            });
          });
        });
      });

      closeButton?.addEventListener('click', closeModal);
      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape' || !(modal instanceof HTMLDialogElement) || !modal.open) return;
        event.preventDefault();
        closeModal();
      });
      modal?.addEventListener('cancel', (event) => {
        event.preventDefault();
        closeModal();
      });
      modal?.addEventListener('click', (event) => {
        if (event.target === modal) closeModal();
      });
    </script>
  </body>
</html>
