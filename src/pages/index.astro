---
import '../styles/global.css';

const techStack = [
  'Java',
  'TypeScript',
  'Quarkus',
  'Spring Boot',
  'Kafka',
  'PostgreSQL',
  'Redis',
  'Docker',
  'AWS',
  'Azure',
  'GCP'
];

const focusAreas = [
  ['Real-time data', 'Exchange feeds, UDP multicast consumers, packet loss detection'],
  ['Backend systems', 'Java services, REST APIs, streaming pipelines, integration design'],
  ['Architecture', 'Technical design, impact analysis, scalable service boundaries'],
  ['Quality', 'Code review, mentoring, automated API and web testing']
];

const highlights = [
  'Designed and developed real-time market data ingestion services with Java, Quarkus, and Gradle.',
  'Integrated exchange feeds from NASDAQ Canada, CBOE, and other market data providers.',
  'Built UDP multicast consumers for high-volume binary market data streams.',
  'Implemented sequence-based packet loss detection and data validation mechanisms.',
  'Led technical design, impact analysis, mentoring, and code review for banking and enterprise systems.'
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Senior Software Engineer focused on Java, TypeScript, real-time data systems, backend services, and streaming pipelines."
    />
    <meta property="og:title" content="Senior Software Engineer | Real-time Data Systems" />
    <meta
      property="og:description"
      content="Java and TypeScript engineer building backend services, streaming pipelines, and practical developer tools."
    />
    <meta property="og:type" content="website" />
    <title>Senior Software Engineer | Real-time Data Systems</title>
  </head>
  <body>
    <main class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-5 py-8 sm:px-8 lg:px-10">
      <header class="flex flex-col gap-5 border-b border-[#17202a]/10 pb-6 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#096b72]">Bangkok, Thailand</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-semibold leading-tight text-[#17202a] sm:text-6xl">
            Senior Software Engineer building real-time data systems.
          </h1>
        </div>

        <nav class="flex flex-wrap gap-3 text-sm font-semibold text-[#17202a]">
          <a class="rounded-full border border-[#17202a]/15 px-4 py-2 transition hover:border-[#096b72] hover:text-[#096b72]" href="https://github.com/kratuwu">GitHub</a>
          <a class="rounded-full border border-[#17202a]/15 px-4 py-2 transition hover:border-[#096b72] hover:text-[#096b72]" href="https://linkedin.com/in/krittawat-sup">LinkedIn</a>
          <a class="rounded-full border border-[#17202a]/15 px-4 py-2 transition hover:border-[#096b72] hover:text-[#096b72]" href="https://www.credly.com/users/krittawat-s">Credly</a>
        </nav>
      </header>

      <section class="grid gap-8 py-12 lg:grid-cols-[1.1fr_0.9fr] lg:py-16">
        <div class="space-y-7">
          <p class="max-w-3xl text-xl leading-8 text-[#46606f]">
            I build backend services, real-time data ingestion systems, microservices, and web applications.
            My recent work focuses on market data ingestion, exchange feed processing, binary protocol decoding,
            and reliable streaming pipelines.
          </p>

          <div class="flex flex-wrap gap-2">
            {techStack.map((tech) => (
              <span class="rounded-full bg-white px-3 py-1.5 text-sm font-medium text-[#17202a] shadow-sm ring-1 ring-[#17202a]/10">
                {tech}
              </span>
            ))}
          </div>
        </div>

        <article class="rounded-2xl bg-[#17202a] p-6 text-white shadow-[0_24px_80px_rgb(23_32_42_/_0.12)]">
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[#f7f5ef]/70">Featured project</p>
          <h2 class="mt-3 text-3xl font-semibold">bangkok-train-fare</h2>
          <p class="mt-4 leading-7 text-[#f7f5ef]/80">
            TypeScript utilities for Bangkok train station lookup, route building, and fare estimation.
            Includes station search, path building, fare calculation, and automated npm publishing.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a class="rounded-full bg-[#f7f5ef] px-4 py-2 text-sm font-semibold text-[#17202a] transition hover:bg-white" href="https://github.com/kratuwu/bangkok-train-fare">
              Repository
            </a>
            <a class="rounded-full border border-white/25 px-4 py-2 text-sm font-semibold text-white transition hover:border-white" href="https://www.npmjs.com/package/bangkok-train-fare">
              npm package
            </a>
          </div>
        </article>
      </section>

      <section class="grid gap-4 border-t border-[#17202a]/10 py-10 md:grid-cols-2">
        {focusAreas.map(([title, detail]) => (
          <article class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-[#17202a]/10">
            <h2 class="text-lg font-semibold text-[#17202a]">{title}</h2>
            <p class="mt-2 leading-7 text-[#46606f]">{detail}</p>
          </article>
        ))}
      </section>

      <section class="grid gap-8 border-t border-[#17202a]/10 py-10 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#096b72]">Recent highlights</p>
          <h2 class="mt-3 text-3xl font-semibold text-[#17202a]">Systems work with sharp edges.</h2>
        </div>
        <ul class="space-y-4">
          {highlights.map((item) => (
            <li class="flex gap-3 leading-7 text-[#46606f]">
              <span class="mt-2 h-2 w-2 flex-none rounded-full bg-[#d94f30]"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <footer class="mt-auto flex flex-col gap-4 border-t border-[#17202a]/10 py-8 text-sm text-[#46606f] sm:flex-row sm:items-center sm:justify-between">
        <p>Open to senior backend, platform, and real-time data engineering conversations.</p>
        <a class="font-semibold text-[#096b72] underline" href="https://github.com/kratuwu/resume">Resume repository</a>
      </footer>
    </main>
  </body>
</html>
