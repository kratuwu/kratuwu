---
import '../styles/global.css';

const heroPhoto =
  'https://images.unsplash.com/photo-1656299436422-0ef09025c56c?auto=format&fit=crop&w=1800&q=85';
const trainPhoto =
  'https://images.unsplash.com/photo-1693506807071-9057fa105172?auto=format&fit=crop&w=1200&q=85';
const stationPhoto =
  'https://images.unsplash.com/photo-1550918551-f41b3b12c927?auto=format&fit=crop&w=1000&q=85';

const techStack = [
  'Java',
  'TypeScript',
  'Quarkus',
  'Spring Boot',
  'Kafka',
  'PostgreSQL',
  'Redis',
  'Docker',
  'AWS',
  'Azure',
  'GCP'
];

const strengths = [
  ['Market data', 'Exchange feeds, binary protocols, validation, replay-aware data handling'],
  ['Streaming systems', 'Kafka, ingestion pipelines, durable processing, operational reliability'],
  ['Service design', 'REST APIs, integration-heavy workflows, scalable backend boundaries'],
  ['Team impact', 'Technical design, impact analysis, code review, mentoring']
];

const highlights = [
  'Designed and developed real-time market data ingestion services with Java, Quarkus, and Gradle.',
  'Integrated exchange feeds from NASDAQ Canada, CBOE, and other market data providers.',
  'Built UDP multicast consumers for high-volume binary market data streams.',
  'Implemented sequence-based packet loss detection and data validation mechanisms.',
  'Led technical design, impact analysis, mentoring, and code review for banking and enterprise systems.'
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Senior Software Engineer focused on Java, TypeScript, real-time data systems, backend services, transit tools, and photography."
    />
    <meta property="og:title" content="Senior Software Engineer | Real-time Data Systems" />
    <meta
      property="og:description"
      content="Java and TypeScript engineer building backend services, streaming pipelines, Bangkok transit tooling, and photography-informed web profiles."
    />
    <meta property="og:type" content="website" />
    <title>Senior Software Engineer | Real-time Data Systems</title>
  </head>
  <body>
    <main>
      <section class="relative min-h-[88svh] overflow-hidden bg-[#111417] text-white">
        <img
          class="absolute inset-0 h-full w-full object-cover"
          src={heroPhoto}
          alt="Bangkok city street and elevated train at night"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/35 to-[#111417]"></div>

        <div class="relative mx-auto flex min-h-[88svh] w-full max-w-7xl flex-col px-5 py-6 sm:px-8 lg:px-10">
          <header class="flex items-center justify-between gap-4">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[#f8d684]">Bangkok based</p>
            <nav class="flex flex-wrap justify-end gap-2 text-sm font-semibold">
              <a class="rounded-full bg-white/10 px-4 py-2 text-white ring-1 ring-white/20 transition hover:bg-white hover:text-[#111417]" href="https://github.com/kratuwu">GitHub</a>
              <a class="rounded-full bg-white/10 px-4 py-2 text-white ring-1 ring-white/20 transition hover:bg-white hover:text-[#111417]" href="https://linkedin.com/in/krittawat-sup">LinkedIn</a>
              <a class="rounded-full bg-white/10 px-4 py-2 text-white ring-1 ring-white/20 transition hover:bg-white hover:text-[#111417]" href="https://www.credly.com/users/krittawat-s">Credly</a>
            </nav>
          </header>

          <div class="mt-auto max-w-4xl pb-10 pt-24">
            <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-[#f8d684]">
              Java / TypeScript / Real-time data
            </p>
            <h1 class="text-5xl font-semibold leading-[0.98] sm:text-7xl lg:text-8xl">
              Engineering systems with a photographer's eye for detail.
            </h1>
            <p class="mt-7 max-w-2xl text-lg leading-8 text-white/82 sm:text-xl">
              I build backend services, market data ingestion systems, streaming pipelines, and practical web tools.
              Outside code, photography keeps me tuned to composition, timing, and quiet observation.
            </p>
          </div>
        </div>
      </section>

      <section class="bg-[#f4efe5] px-5 py-14 text-[#17202a] sm:px-8 lg:px-10">
        <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.95fr_1.05fr]">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#9a3f2f]">Current focus</p>
            <h2 class="mt-3 text-4xl font-semibold leading-tight sm:text-5xl">
              Real-time data, backend architecture, and transit-shaped side projects.
            </h2>
          </div>
          <div class="grid gap-3 sm:grid-cols-2">
            {strengths.map(([title, detail]) => (
              <article class="rounded-[2px] bg-white p-5 shadow-sm ring-1 ring-black/8">
                <h3 class="text-lg font-semibold">{title}</h3>
                <p class="mt-2 leading-7 text-[#526064]">{detail}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-[#111417] px-5 py-16 text-white sm:px-8 lg:px-10">
        <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
          <article>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#f8d684]">Featured package</p>
            <h2 class="mt-4 text-5xl font-semibold leading-none sm:text-6xl">bangkok-train-fare</h2>
            <p class="mt-6 max-w-2xl text-lg leading-8 text-white/75">
              TypeScript utilities for Bangkok train station lookup, route building, and fare estimation.
              It connects my software work with daily city infrastructure: practical data, clear APIs, and a local problem space.
            </p>
            <div class="mt-7 flex flex-wrap gap-3">
              <a class="rounded-full bg-[#f8d684] px-5 py-3 text-sm font-semibold text-[#111417] transition hover:bg-white" href="https://github.com/kratuwu/bangkok-train-fare">
                Repository
              </a>
              <a class="rounded-full border border-white/25 px-5 py-3 text-sm font-semibold text-white transition hover:border-white" href="https://www.npmjs.com/package/bangkok-train-fare">
                npm package
              </a>
            </div>
          </article>

          <figure class="overflow-hidden rounded-[2px] bg-white/5">
            <img class="aspect-[4/3] w-full object-cover" src={trainPhoto} alt="Bangkok train moving through an urban rail corridor" />
            <figcaption class="border-t border-white/10 px-4 py-3 text-sm text-white/62">
              Transit, city movement, and data become the same subject from different distances.
            </figcaption>
          </figure>
        </div>
      </section>

      <section class="bg-white px-5 py-16 text-[#17202a] sm:px-8 lg:px-10">
        <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.78fr_1.22fr]">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#096b72]">Photography</p>
            <h2 class="mt-3 text-4xl font-semibold leading-tight sm:text-5xl">
              A hobby that changes how I build.
            </h2>
            <p class="mt-5 leading-8 text-[#526064]">
              Photography trains patience, framing, and noticing small signals before they become obvious.
              I like carrying that same habit into debugging, architecture, and product details.
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-[0.9fr_1.1fr]">
            <figure class="overflow-hidden rounded-[2px] bg-[#17202a] text-white">
              <img class="aspect-[3/4] w-full object-cover" src={stationPhoto} alt="Bangkok train station interior with reflected light" />
              <figcaption class="px-4 py-4 text-sm leading-6 text-white/70">
                Light, geometry, timing: useful in photographs, useful in systems.
              </figcaption>
            </figure>

            <div class="grid content-between gap-4">
              <div class="rounded-[2px] bg-[#f4efe5] p-6">
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#9a3f2f]">Tech stack</p>
                <div class="mt-5 flex flex-wrap gap-2">
                  {techStack.map((tech) => (
                    <span class="rounded-full bg-white px-3 py-1.5 text-sm font-medium text-[#17202a] shadow-sm ring-1 ring-black/8">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>

              <div class="rounded-[2px] border border-[#17202a]/10 p-6">
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#096b72]">Recent highlights</p>
                <ul class="mt-5 space-y-4">
                  {highlights.map((item) => (
                    <li class="flex gap-3 leading-7 text-[#526064]">
                      <span class="mt-2.5 h-2 w-2 flex-none rounded-full bg-[#d94f30]"></span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </section>

      <footer class="bg-[#111417] px-5 py-8 text-sm text-white/64 sm:px-8 lg:px-10">
        <div class="mx-auto flex max-w-7xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <p>Open to senior backend, platform, and real-time data engineering conversations.</p>
          <a class="font-semibold text-[#f8d684] underline" href="https://github.com/kratuwu/resume">Resume repository</a>
        </div>
      </footer>
    </main>
  </body>
</html>
